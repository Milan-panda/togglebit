{
  "name": "togglebit-monorepo",
  "private": true,
  "scripts": {
    "sdk:build": "pnpm --filter ./packages/sdk build",
    "sdk:dev": "pnpm --filter ./packages/sdk dev",
    "dashboard:dev": "pnpm --filter ./apps/dashboard dev",
    "dashboard:build": "pnpm --filter ./apps/dashboard build",
    "dashboard:lint": "pnpm --filter ./apps/dashboard lint",
    "docker:dev": "docker compose -f docker-compose.yml up --build",
    "docker:prod": "docker compose -f docker-compose-prod.yml up -d --build",
    "docker:down": "docker compose -f docker-compose.yml down",
    "docker:prod:down": "docker compose -f docker-compose-prod.yml down"
  }
}
